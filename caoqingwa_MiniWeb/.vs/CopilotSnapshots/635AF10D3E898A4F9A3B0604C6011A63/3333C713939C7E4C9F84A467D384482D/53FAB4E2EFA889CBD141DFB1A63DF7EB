#include "event_loop.h"
#include <winsock2.h>
#pragma comment(lib, "ws2_32.lib")

class SelectLoop : public EventLoop {
private:
    SOCKET server_fd;
    fd_set master_set;

public:
    void init(int port) override {
        WSADATA wsa;
        WSAStartup(MAKEWORD(2, 2), &wsa);

        server_fd = socket(AF_INET, SOCK_STREAM, 0);

        sockaddr_in addr{};
        addr.sin_family = AF_INET;
        addr.sin_port = htons(port);
        addr.sin_addr.s_addr = INADDR_ANY;

        bind(server_fd, (sockaddr*)&addr, sizeof(addr));
        listen(server_fd, 5);

        FD_ZERO(&master_set);
        FD_SET(server_fd, &master_set);
    }

    void loop() override {
        while (true) {
            fd_set read_set = master_set;
            select(0, &read_set, NULL, NULL, NULL);

            for (int i = 0; i < read_set.fd_count; i++) {
                SOCKET sock = read_set.fd_array[i];

                if (sock == server_fd) {
                    SOCKET client = accept(server_fd, nullptr, nullptr);
                    FD_SET(client, &master_set);
                }
                else {
                    char buf[1024];
                    int len = recv(sock, buf, sizeof(buf), 0);

                    if (len <= 0) {
                        closesocket(sock);
                        FD_CLR(sock, &master_set);
                    }
                    else {
                        send(sock, "HTTP/1.1 200 OK\r\n\r\nHello", 26, 0);
                    }
                }
            }
        }
    }
};